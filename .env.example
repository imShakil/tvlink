PLAYLIST_SOURCES=https://source1.example.com/playlist.m3u8,https://sourc2.example.com/playlist.m3u8
SOURCE_PASSPHRASE=change-this-passphrase
VALIDATE_STREAMS=true
LIVENESS_WORKERS=40
LIVENESS_TIMEOUT_SECONDS=4
OUTPUT_FILE=iptv.m3u8

# Optional curated playlist that keeps only Football World Cup channels.
PRIVATE_OUTPUT_FILE=private.m3u
# Comma-separated keywords used to detect World Cup channels (defaults to
# "world cup,fifawc,fifa world,fifa,wc"). Leave empty to use defaults.
PRIVATE_FILTER_KEYWORDS=

# Required only for local token refresh via autorun.sh
PLAY_URL=<player-url>
REFERER=<referrer>
SPOOF_IP=<ip>
